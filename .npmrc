# pnpm settings.
#
# Expo + NativeWind + Reanimated rely on Babel plugins that resolve modules by name
# from deep inside .pnpm (e.g. @babel/core requiring 'react-native-worklets/plugin',
# @expo/config-plugins requiring 'expo-router/build/index'). pnpm's default
# isolated layout hides those from the resolver. `node-linker=hoisted` switches
# pnpm to a flat node_modules layout (like npm/yarn-classic), which is what the
# RN/Expo toolchain assumes.
node-linker=hoisted
