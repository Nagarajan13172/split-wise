# --- Local Postgres (mapped to 5433 on host to avoid conflict with any local Postgres on 5432) ---
DATABASE_URL="postgresql://splitwise:splitwise@localhost:5433/splitwise?schema=public"

# --- Local Redis ---
REDIS_URL="redis://localhost:6380"

# --- Local S3 (MinIO) ---
S3_ENDPOINT="http://localhost:9002"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minio"
S3_SECRET_ACCESS_KEY="minio12345"
S3_BUCKET_RECEIPTS="splitwise-receipts"
S3_BUCKET_AVATARS="splitwise-avatars"
S3_FORCE_PATH_STYLE="true"

# --- API ---
API_PORT=4000
API_BASE_URL="http://localhost:4000"
JWT_ACCESS_SECRET="dev-access-secret-change-me-this-is-32-bytes-min"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me-this-is-32-bytes-min"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# --- CORS ---
WEB_ORIGIN="http://localhost:5173"

# --- Email ---
# Dev: SMTP to local Mailpit (web UI at http://localhost:8025)
# Prod: leave SMTP_* empty and set RESEND_API_KEY to use Resend
EMAIL_FROM="Splitwise <noreply@localhost>"
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_SECURE="false"
RESEND_API_KEY=""

# --- App URLs used in emails ---
APP_BASE_URL="http://localhost:5173"

# --- Google OAuth ---
# Get from https://console.cloud.google.com/apis/credentials (Web application client).
# CLIENT_ID is required to enable Google sign-in. SECRET is reserved for future flows.
# VITE_GOOGLE_CLIENT_ID is the same value, exposed to the web bundle.
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
VITE_GOOGLE_CLIENT_ID=""

# --- Logging ---
LOG_LEVEL="debug"
NODE_ENV="development"
