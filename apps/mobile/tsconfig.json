{
  "extends": "@split-wise/config-tsconfig/react-native.json",
  "compilerOptions": {
    "baseUrl": ".",
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
