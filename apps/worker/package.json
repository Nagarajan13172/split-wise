{
  "name": "@split-wise/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3",
    "@prisma/client": "^6.1.0",
    "@split-wise/prisma": "workspace:*",
    "@split-wise/shared": "workspace:*",
    "bullmq": "^5.34.7",
    "ioredis": "^5.4.2",
    "node-tesseract-ocr": "^2.2.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "sharp": "^0.34.5",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@split-wise/config-eslint": "workspace:*",
    "@split-wise/config-tsconfig": "workspace:*",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
